# Configuration du Projet de Classification de Produits E-commerce
# Copiez ce fichier en .env et remplissez les valeurs

# Chemins des données
DATA_DIR=data brut
TRAIN_X_FILE=X_train_update.csv
TRAIN_Y_FILE=Y_train.csv
TEST_X_FILE=X_test_update.csv

# Chemins de sortie
OUTPUT_DIR=output
MODELS_DIR=models
REPORTS_DIR=reports

# Paramètres de preprocessing
MIN_TEXT_LENGTH=3
MAX_TEXT_LENGTH=10000

# Paramètres de modélisation
RANDOM_STATE=42
TEST_SIZE=0.2
VALIDATION_SIZE=0.2

# Paramètres NLP
LANGUAGE=fr
REMOVE_HTML=true
REMOVE_ACCENTS=false
LOWERCASE=true

# Paramètres de visualisation
FIGURE_FORMAT=png
FIGURE_DPI=300
PLOT_STYLE=seaborn

# Paramètres de logging
LOG_LEVEL=INFO
LOG_FILE=logs/project.log

